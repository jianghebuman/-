# Copy this file to /opt/campus-recruitment/.env on the server and edit values.

SERVER_PORT=8081
SERVER_CONTEXT_PATH=/api

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=campus_recruitment
DB_USERNAME=campus_user
DB_PASSWORD=change_me

# Use a long random value in production.
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRE=604800000

CAMPUS_UPLOAD_PATH=/opt/campus-recruitment/upload/
CAMPUS_UPLOAD_PREFIX=/upload/

ENTERPRISE_VERIFY_ENABLED=false
ENTERPRISE_VERIFY_SOURCE_NAME=国家企业信用信息公示系统
ENTERPRISE_VERIFY_SOURCE_URL=https://www.gsxt.gov.cn/
# Fill with a licensed enterprise registry data API. Supports {creditCode} and {companyName}.
ENTERPRISE_VERIFY_QUERY_URL=
ENTERPRISE_VERIFY_COMPANY_NAME_FIELD=data.companyName
ENTERPRISE_VERIFY_CREDIT_CODE_FIELD=data.creditCode
ENTERPRISE_VERIFY_STATUS_FIELD=data.status
ENTERPRISE_VERIFY_NORMAL_STATUSES=存续,在业,正常,开业

LOG_FILE=/opt/campus-recruitment/logs/campus-recruitment.log
LOG_LEVEL_ROOT=info
LOG_LEVEL_CAMPUS=info

JAVA_OPTS="-Xms256m -Xmx512m"
